#Notch signaling
design_AKT_m <-
model.matrix(~ annot_tum_mut$RTK_Ras_PI3K_AKT_mTOR_Signaling - 1)
colnames(design_AKT_m) <- c("RTK_Ras_PI3K_AKT_mTOR_Signalingmut", "RTK_Ras_PI3K_AKT_mTOR_Signalingwt")
fit_AKT_m <- lmFit(d0$counts, design_AKT_m)
contrast.matrix_AKT_m <- makeContrasts("RTK_Ras_PI3K_AKT_mTOR_Signalingmut-RTK_Ras_PI3K_AKT_mTOR_Signalingwt",
levels = design_AKT_m)
fit_AKT_m <- contrasts.fit(fit_AKT_m, contrast.matrix_AKT_m)
fit_AKT_m <- eBayes(fit_AKT_m)
AKT_m_results <- topTable(fit_AKT_m, number = 1708)
# Save result table
AKT_m_results_tb <- AKT_m_results %>%
rownames_to_column(var = "gene")
#write.table(AKT_m_results_tb,
#            "transcript_analysis_results/DEGs_RTK_Ras_PI3K.txt",
#            row.names = F, col.names = TRUE, sep = "\t")
volcanoplot(fit_AKT_m, highlight = 10,
names = rownames(fit_AKT_m),
main = "RAS/PI3KAKT/mTOR MUT vs WT")
knitr::kable(head(AKT_m_results, n = 15))
#Notch signaling
