segments <- read.table("file/WIAB_IDPE_P53.called.seg", header = TRUE,
sep = "\t", comment.char = "@")
amp_segments <- segments[segments$MEAN_LOG2_COPY_RATIO > 1, ]
segments_gr <- GRanges(
seqnames = amp_segments$CONTIG,
ranges = IRanges(start = amp_segments$START, end = amp_segments$END),
MEAN_LOG2_COPY_RATIO = amp_segments$MEAN_LOG2_COPY_RATIO,
CALL = amp_segments$CALL
)
library(GenomicRanges)
library(biomaRt)
segments <- read.table("file/WIAB_IDPE_P53.called.seg", header = TRUE,
sep = "\t", comment.char = "@")
amp_segments <- segments[segments$MEAN_LOG2_COPY_RATIO > 1, ]
segments_gr <- GRanges(
seqnames = amp_segments$CONTIG,
ranges = IRanges(start = amp_segments$START, end = amp_segments$END),
MEAN_LOG2_COPY_RATIO = amp_segments$MEAN_LOG2_COPY_RATIO,
CALL = amp_segments$CALL
)
# Connect to Ensembl (use the current GRCh38/hg38 release)
mart <- useMart("ensembl", dataset = "hsapiens_gene_ensembl")
genes_hg38 <- getBM(
attributes = c("chromosome_name", "start_position", "end_position", "hgnc_symbol"),
filters = "chromosome_name",
values = c(1:22, "X", "Y"),
mart = mart
)
# Convert to GRanges
genes_gr <- GRanges(
seqnames = paste0("chr", genes_hg38$chromosome_name),
ranges = IRanges(start = genes_hg38$start_position, end = genes_hg38$end_position),
gene_symbol = genes_hg38$hgnc_symbol
)
overlaps <- findOverlaps(segments_gr, genes_gr)
amp_genes <- data.frame(
as.data.frame(segments_gr[queryHits(overlaps), ]),
gene_symbol = genes_gr$gene_symbol[subjectHits(overlaps)]
)
write_tsv(amp_genes,
"~/Desktop/Whetstine_Lab/WIAB_IDPE_analysis/GATK_CNV/segments/annotation/WIAB_IDPE_P53_merged_annotated.tsv")
library(tidyverse)
write_tsv(amp_genes,
"~/Desktop/Whetstine_Lab/WIAB_IDPE_analysis/GATK_CNV/segments/annotation/WIAB_IDPE_P53_merged_annotated.tsv")
View(amp_genes)
