# List only files with .marked.bintest.genemetrics.txt
files <- list.files(pattern = "\\_genemetrics\\_t\\_1.txt$")
# Create a new Excel workbook
wb <- createWorkbook()
# Extract sample name (without extension)
sample_name <- gsub("\\_genemetrics\\_t\\_1.txt$", "", f)
# Loop over each file
for (f in files) {
# Read the gene metrics file
df <- read_tsv(f, col_types = cols())
# Extract sample name (without extension)
sample_name <- gsub("\\_genemetrics\\_t\\_1.txt$", "", f)
# Optional: add Sample column
df <- df %>% mutate(Sample = sample_name)
# Add a sheet to the workbook
addWorksheet(wb, sample_name)
writeData(wb, sheet = sample_name, df)
}
