design_CELLC <-
model.matrix(~ annot_tum_mut$Cell_Cycle_Control - 1)
colnames(design_CELLC) <- c("Cell_Cycle_MUT", "Cell_Cycle_WT")
fit_CELLC <- lmFit(d0$counts, design_CELLC)
contrast.matrix_CELLC <- makeContrasts("Cell_Cycle_MUT-Cell_Cycle_WT",
levels = design_CELLC)
fit_CELLC <- contrasts.fit(fit_CELLC, contrast.matrix_CELLC)
fit_CELLC <- eBayes(fit_CELLC)
CELLC_results <- topTable(fit_CELLC, number = 1708)
# Save result table
CELLC_results_tb <- CELLC_results %>%
rownames_to_column(var = "gene")
write_xlsx(CELLC_results_tb,
"DSP_results//DSP_CellCycle.xlsx")
volcanoplot(fit_CELLC, highlight = 10,
names = rownames(fit_CELLC),
main = "Cell Cycle signaling mutated vs WT")
knitr::kable(head(CELLC_results, n = 15))
CELLC_results_tb$DEGs <- "padj > 0.05"
CELLC_results_tb$DEGs[CELLC_results_tb$logFC > 0.5 &
CELLC_results_tb$P.Value < 0.05] <- "p < 0.05; lfc > 1"
CELLC_results_tb$DEGs[CELLC_results_tb$logFC < -0.5 &
CELLC_results_tb$P.Value < 0.05] <- "p < 0.05; lfc < -1"
mycolors <- c("dodgerblue3", "firebrick3", "gainsboro")
names(mycolors) <- c("p < 0.05; lfc < -1", "p < 0.05; lfc > 1", "padj > 0.05")
CELLC_results_tb$delabel <- NA
CELLC_results_tb$delabel[CELLC_results_tb$DEGs != "p > 0.05"] <- CELLC_results_tb$gene[CELLC_results_tb$DEGs != "p > 0.05"]
p_hemi <- ggplot(data = CELLC_results_tb,
aes(x = logFC,
y = -log10(P.Value),
col = DEGs,
label = delabel)) +
geom_point() +
theme_article() +
#geom_vline(xintercept = c(-.5, 0.5), col = "red") +
#geom_hline(yintercept= -log10(0.05), col = "red") +
scale_colour_manual(values = mycolors) +
geom_text_repel(max.overlaps = 5) +
theme(legend.key.size = unit(2, "mm"),
legend.text = element_text(size = 6),
legend.title = element_text(size = 7)) +
# Size of legend symbols
guides(color = guide_legend(override.aes = list(size = 2))) +
ylim(c(0,4)) +
xlim(c(-20,30))
p_hemi
