levels = design_PI3K_AKT_m)
fit_PI3K_AKT_m <- contrasts.fit(fit_PI3K_AKT_m, contrast.matrix_AKT_m)
fit_PI3K_AKT_m <- eBayes(fit_PI3K_AKT_m)
PI3K_AKT_m_results <- topTable(fit_PI3K_AKT_m, number = 1708)
